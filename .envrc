# Automatically activate the Nix dev shell defined in shell.nix when you
# cd into this directory.
#
# Requires direnv (https://direnv.net) and nix-direnv for cached evaluation:
#   - NixOS:        programs.direnv.enable = true; (sets up the shell hook)
#   - nix-on-droid: nix-env -iA nixpkgs.direnv
#
# First-time setup:
#   direnv allow
#
# nix-direnv is strongly recommended – it caches the shell derivation so
# re-entering the directory is instant even after a Nix GC.  Without it
# `use nix` re-evaluates shell.nix on every shell entry.
#
#   home.packages = [ pkgs.nix-direnv ];  # home-manager
#   # or
#   nix-env -iA nixpkgs.nix-direnv
use nix
